# Sources enabled for the run
sources:
  enabled:
    - reddit
    # - facebook

# Subreddits to monitor — hardcoded, LLM cannot modify this list
subreddits: 

# Facebook source settings
facebook:
  mode: manual_json
  groups:
    -
  manual_input_path: data/import/facebook_posts.json
  queries_per_group:
  max_queries_per_run:
  selenium:
    headless: true
    max_scrolls:
    scroll_pause_seconds:
    group_urls: {}

# Budget caps — enforced in code, LLM can never exceed these
budget:
  max_cost_usd: 
  max_items_per_run: 
  max_queries_per_run: 
  time_window_hours: 

# Matching configuration
match:
  min_confidence_threshold: 
  max_matches_per_item: 
  batch_size: 
  min_text_length: 
  max_author_occurrences_per_run: 

# Precision-first tuning
precision:
  per_tag_confidence_thresholds:
    coding: 
    trivia: 
    dance: 
    climbing: 
    social: 
  explicit_intent_bonus: 
  ambiguous_intent_penalty: 
  future_intent_penalty:
  explicit_intent_patterns:
    - 
  ambiguous_intent_patterns:
    - 
  future_intent_patterns:
    -
  hard_negative_patterns:
    - 

# Tag auto-derivation keyword map (used when parentInterestIds is empty)
tag_keywords:
  

# LLM configuration (Groq)
llm:
  primary_model: llama-3.3-70b-versatile  # Node C (planning) + Node G (matching)
  fast_model: llama-3.1-8b-instant         # Node H (user summaries)
  temperature: 0.1
  max_tokens: 1024

# Data retention
retention_days: 30
